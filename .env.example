
# Copiez ce fichier vers ".env" (sans .example) et renseignez vos valeurs.
# Ce même fichier sert à la fois à Docker Compose (base PostgreSQL) et à
# l'application Python (src/load/db.py) — un seul endroit à modifier.
# ".env" est déjà exclu du versionnement par .gitignore — ne le committez jamais.

DB_PASSWORD=

# Optionnels — les valeurs par défaut dans docker-compose.yml et
# config/settings.yaml conviennent pour un usage local standard.
DB_USER=postgres
DB_NAME=cadence_trs
DB_PORT=5433

CADENCE_TRS_API_KEY=